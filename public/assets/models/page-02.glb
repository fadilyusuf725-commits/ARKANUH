212/6d321da4-2ae9-4b94-bfaf-f90948fc6ee1/autoadjusted.jpeg",{"max_retries":31,"used_retries":31,"remaining_retries":31,"can_retry":32,"can_show_retry":32},{"owner_name":254,"owner_avatar":173,"id":255,"project_name":256,"like_count":31,"collect_count":31,"liked":32,"collected":32,"type":69,"visibility":70,"biz_info":257,"custom_tags":261,"category":181,"style":182,"use_case":183,"is_featured":32,"cover_image":262,"is_nsfw":32,"model_url":265,"point_cloud_model_url":266,"is_owner":32,"operator":267,"retry_info":282},"Anonymous1770870356","8ffa193f-bdae-430d-857b-023ea7c39251","बच्चों का 3d मॉडल",{"description":258,"short_description":259,"display_image":260},"एक छोटे से शहर में आरव और सिया रहते थे। दोनों एक ही कॉलेज में पढ़ते थे, लेकिन कभी ठीक से बात नहीं हुई थी। सिया पढ़ाई में बहुत तेज थी और हमेशा लाइब्रेरी में किताबों के बीच खोई रहती थी। आरव शांत स्वभाव का था और उसे पेंटिंग का शौक था।\n\nएक दिन कॉलेज में आर्ट एग्ज़िबिशन लगी। सिया वहाँ अपनी दोस्त के कहने पर गई। दीवार पर लगी एक पेंटिंग ने उसका ध्यान खींचा—बारिश में खड़ी एक लड़की, जिसके चेहरे पर हल्की मुस्कान थी। सिया को लगा जैसे वो पेंटिंग उसकी ही कहानी कह रही हो। तभी उसे पता चला कि वो पेंटिंग आरव ने बनाई है।\n\nधीरे-धीरे दोनों की बात शुरू हुई। सिया को आरव की सादगी पसंद आई और आरव को सिया की समझदारी। लाइब्रेरी की खामोशी अब उनके लिए खास बन गई थी। वक्त के साथ दोस्ती गहरी हुई और एक दिन आरव ने मुस्कुराकर कहा, “तुम मेरी सबसे खूबसूरत पेंटिंग हो।” सिया की आँखों में चमक थी—और वहीं से उनकी नई कहानी शुरू हुई।","एक छोटे से शहर में आरव और सिया रहते थे दोनों एक ही कॉलेज में पढ़ते थे","https://tripo-public.tripo3d.ai/studio/project/8ffa193f-bdae-430d-857b-023ea7c39251/एक-छोटे-से-शहर-में-आरव-और-सिया-रहते-थे-दोनों-एक-ही-कॉलेज-में-पढ़ते-थे.webp",[],[263,264],"https://tripo-data.rg1.data.tripo3d.com/tripo-studio/20260212/0a64223f-bbb8-4098-b8ac-ff1a348053c6/studio_mesh.webp?Key-Pair-Id=K1676C64NMVM2J&Policy=eyJTdGF0ZW1lbnQiOlt7IlJlc291cmNlIjoiaHR0cHM6Ly90cmlwby1kYXRhLnJnMS5kYXRhLnRyaXBvM2QuY29tL3RyaXBvLXN0dWRpby8yMDI2MDIxMi8wYTY0MjIzZi