{
  "name": "arkanuh",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open /ARKANUH/",
    "dev:local": "vite --host 127.0.0.1 --open /ARKANUH/",
    "dev:network": "vite --host 0.0.0.0 --open /ARKANUH/",
    "start": "npm run dev:local",
    "models:prepare": "node scripts/prepare-tripo-models.mjs",
    "build": "tsc -b && vite build",
    "postbuild": "node ./scripts/create-spa-fallback.mjs",
    "preview": "vite preview --open /ARKANUH/",
    "preview:local": "vite preview --host 127.0.0.1 --open /ARKANUH/",
    "preview:network": "vite preview --host 0.0.0.0 --open /ARKANUH/"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9"
  }
}
